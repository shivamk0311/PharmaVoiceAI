
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient{
  id String @id @default(uuid())
  fullName String
  phoneNumber String
  dateOfBirth DateTime
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zipCode      String?

  medicationName String
  copayAmount    Decimal
  hasCardOnFile  Boolean @default(false)

  callSessions CallSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model CallSession{
  id String @id @default(uuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  vapiCallId String? @unique

  status  CallStatus @default(PENDING)
  conversationState    ConversationState @default(GREETING)

  verificationPassed Boolean @default(false)

  refillConfirmed Boolean?

  paymentChoice PaymentChoice?

  paymentStatus PaymentStatus @default(NOT_STARTED)

  fulfillmentChoice FulfillmentChoice?
  deliveryAddress   String?

  transcript String?

  needsFollowUp Boolean @default(false)

  followUpReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CallStatus{
  PENDING
  CALLING
  COMPLETED
  FAILED
}

enum PaymentChoice{
  PAYMENT_LINK
  CARD_ON_FILE
}

enum FulfillmentChoice {
  PICKUP
  DELIVERY
}

enum PaymentStatus {
  NOT_STARTED
  PENDING_STAFF_ACTION
  LINK_REQUESTED
  LINK_SENT
  COMPLETED
  FAILED
}

enum ConversationState {
  GREETING
  VERIFY_NAME
  VERIFY_DOB
  REFILL_DISCUSSION
  PAYMENT_SELECTION
  PAYMENT_PROCESSING
  FULFILLMENT_CHOICE
  FOLLOW_UP
  COMPLETED
}
