
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient{
  id String @id @default(uuid())
  fullName String
  phoneNumber String
  dateOfBirth DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
